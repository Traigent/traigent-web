{
  "name": "traigent-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "homepage": "https://www.traigent.ai",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "version": "./scripts/update-version.sh",
    "dev": "vite",
    "start": "vite",
    "prebuild": "./scripts/update-version.sh",
    "build": "vite build && node -e \"const fs=require('fs'); const path=require('path'); const src=path.join('public','404.html'); const dest=path.join('dist','404.html'); if (fs.existsSync(src)) fs.copyFileSync(src, dest);\"",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "framer-motion": "^10.16.4",
    "lucide-react": "^0.284.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.16.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.45.0",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.3",
    "gh-pages": "^6.0.0",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.3",
    "vite": "^7.2.6"
  }
}
