# Copy this file to .env.local and fill in your IDs.
# .env.local is gitignored, so secrets won't leak.

# Google Analytics 4 — get from https://analytics.google.com (Admin → Data Streams)
VITE_GA4_ID=

# Microsoft Clarity — get from https://clarity.microsoft.com (free, 30 sec sign-up)
VITE_CLARITY_ID=

# HubSpot — Portal ID is the number after /contacts/ in your HubSpot URL.
# Region: leave blank for US accounts (app.hubspot.com); set to "eu1" for EU (app-eu1.hubspot.com).
VITE_HUBSPOT_PORTAL_ID=
VITE_HUBSPOT_REGION=

# PostHog — get from https://posthog.com (Project Settings → Project Variables).
# Host is https://us.posthog.com or https://eu.posthog.com depending on the region you chose.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=
